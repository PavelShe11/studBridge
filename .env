# auth
AUTH_POSTGRES_DB_HOST=auth-db-postgres
AUTH_POSTGRES_DB_EXTERNAL_PORT=5555
AUTH_POSTGRES_DB_INTERNAL_PORT=5432
AUTH_POSTGRES_DB_NAME=auth-micro-db
AUTH_POSTGRES_DB_USER=postgres
AUTH_POSTGRES_DB_PASSWORD=postgres
AUTH_PGSSLMODE_STATUS=disable

# tokens
# 5 min
ACCESS_TOKEN_LIFETIME=86400000
# 5 days
REFRESH_TOKEN_LIFETIME=432000000

# code
CODE_LIFETIME_MINUTES=5
ACTUAL_CODE_PATTERN=[0-9]{6}

# clean
REGISTRATION_LOGIN_SESSION_CLEAN_TIME=600000
CODE_CLEAN_TIME=300000
REFRESH_TOKEN_SESSION_CLEAN_TIME=3600000
# config
ENV_GRPC_CONFIG_JSON=grpc-config.json
#1 december
ENV_ACTUALIZE_INSTITUTION_SPECIALITIES_TIME=0 0 0 1 12 ? *
# test
# ENV_ACTUALIZE_INSTITUTION_SPECIALITIES_TIME=0 * * * * ?

# swagger
ENV_SWAGGER_LICENSE_URL=https://www.apache.org/licenses/LICENSE-2.0.html
